{
  "fleet_name": "fleet-02-scenario-builder",
  "type": "iterative",
  "config": {
    "max_concurrent": 5,
    "model": "sonnet",
    "fallback_model": "sonnet",
    "provider": "claude"
  },
  "stop_when": {
    "max_iterations": 5,
    "reviewer_lgtm_count": 1
  },
  "workers": [
    {
      "id": "canvas-worker",
      "model": "sonnet",
      "type": "code-run",
      "max_budget_per_iter": 10.00,
      "depends_on": []
    },
    {
      "id": "controls-worker",
      "model": "sonnet",
      "type": "code-run",
      "max_budget_per_iter": 10.00,
      "depends_on": []
    },
    {
      "id": "scorer-worker",
      "model": "sonnet",
      "type": "code-run",
      "max_budget_per_iter": 10.00,
      "depends_on": []
    },
    {
      "id": "persistence-worker",
      "model": "sonnet",
      "type": "code-run",
      "max_budget_per_iter": 10.00,
      "depends_on": []
    },
    {
      "id": "integration-worker",
      "model": "opus",
      "type": "code-run",
      "max_budget_per_iter": 10.00,
      "depends_on": []
    },
    {
      "id": "reviewer",
      "model": "opus",
      "type": "reviewer",
      "max_budget_per_iter": 10.00,
      "depends_on": ["canvas-worker", "controls-worker", "scorer-worker", "persistence-worker", "integration-worker"]
    }
  ]
}
