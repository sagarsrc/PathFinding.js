[19.710747, "o", " empty array is returned, either\\n67\\t * no path is possible, or the maximum execution time is reached.\\n68\\t *\\n69\\t * @return {Array<Array<number>>} The path, including both start and\\n70\\t *     end positions.\\n71\\t */\\n72\\tIDAStarFinder.prototype.findPath = function(startX, startY, endX, endY, grid) {\\n73\\t    // Used for statistics:\\n74\\t    var nodesVisited = 0;\\n75\\t\\n76\\t    // Execution time limitation:\\n77\\t    var startTime = new Date().getTime();\\n78\\t\\n79\\t    // Heuristic helper:\\n80\\t    var h = function(a, b) {\\n81\\t        return this.heuristic(Math.abs(b.x - a.x), Math.abs(b.y - a.y));\\n82\\t    }.bind(this);\\n83\\t\\n84\\t    // Step cost from a to b:\\n85\\t    var cost = function(a, b) {\\n86\\t        return (a.x === b.x || a.y === b.y) ? 1 : Math.SQRT2;\\n87\\t    };\\n88\\t\\n89\\t    /**\\n90\\t     * IDA* search implementation.\\n91\\t     *\\n92\\t     * @param {Node} The node currently expanding from.\\n93\\t     * @param {number} Cost to reach the given node.\\n94\\t     * @param {number} Maximum search "]
